# Frère Jacques — 36 notes, full sequence cycles every 18s → 2 notes/sec
let notes = [262, 294, 330, 262, 262, 294, 330, 262, 330, 349, 392, 392, 330, 349, 392, 392, 392, 440, 392, 349, 330, 262, 392, 440, 392, 349, 330, 262, 262, 196, 262, 262, 262, 196, 262, 262]
let freq = wave(2.0 / 36, notes)
osc(sin, freq) * 0.25
